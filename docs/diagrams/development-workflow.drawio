        </mxCell>
        <mxCell id='ci-lint' value='Lint&#xa;ESLint check' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;' vertex='1' parent='lane-parallel'>
          <mxGeometry x='470' y='50' width='110' height='60' as='geometry' />
