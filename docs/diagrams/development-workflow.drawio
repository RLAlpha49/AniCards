        <mxCell id='ci-typecheck' value='Type Check&#xa;tsc --noEmit' style='rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;' vertex='1' parent='lane-parallel'>
