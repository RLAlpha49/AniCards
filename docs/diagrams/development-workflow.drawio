  <diagram id='ci-pipeline' name='CI Pipeline'>
    <mxGraphModel dx='1422' dy='762' grid='1' gridSize='10' guides='1' tooltips='1' connect='1' arrows='1' fold='1' page='1' pageScale='1' pageWidth='1169' pageHeight='930' math='0' shadow='0'>
