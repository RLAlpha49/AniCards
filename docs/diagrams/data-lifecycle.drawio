    <diagram id="data-deletion" name="Data Deletion and Cleanup">
        <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="830" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="Data Lifecycle: Deletion and Cleanup" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=18;fontStyle=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="40" y="20" width="380" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="note" value="Server-side deletion removes all Redis keys and writes an audit entry. Browser-local artifacts remain until manually cleared." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
                    <mxGeometry x="570" y="20" width="530" height="40" as="geometry"/>
                </mxCell>
                <!-- Trigger -->
                <mxCell id="start" value="Cron detects 3 consecutive&#xa;AniList 404s for a user" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
                    <mxGeometry x="420" y="80" width="320" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="counter" value="failed_updates:{userId}&#xa;incremented on each 404&#xa;14-day TTL auto-expires" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
                    <mxGeometry x="440" y="170" width="280" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="threshold" value="Count &gt;= 3?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
                    <mxGeometry x="490" y="270" width="180" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="no-delete" value="Keep user&#xa;counter expires after 14d" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
                    <mxGeometry x="780" y="280" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="delete-fn" value="deleteUserRecord()&#xa;triggerSource: cron_cleanup_404" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
                    <mxGeometry x="440" y="390" width="280" height="60" as="geometry"/>
                </mxCell>
                <!-- Deleted keys -->
                <mxCell id="lane-deleted" value="Keys Removed by deleteUserRecord()" style="swimlane;startSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="40" y="490" width="1080" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="del-parts" value="All split parts&#xa;user:{id}:{part}&#xa;user:{id}:commit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane-deleted">
                    <mxGeometry x="20" y="40" width="190" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="del-aliases" value="user:{id}:username-aliases&#xa;+ all username:{name} refs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane-deleted">
                    <mxGeometry x="240" y="40" width="220" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="del-cards" value="cards:{userId}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane-deleted">
                    <mxGeometry x="490" y="40" width="160" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="del-indexes" value="users:known-ids (SREM)&#xa;users:stale-by-updated-at (ZREM)&#xa;failed_updates:{userId} (DEL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane-deleted">
                    <mxGeometry x="680" y="40" width="260" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="del-legacy" value="Legacy user:{id} blob&#xa;(if still present)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="lane-deleted">
                    <mxGeometry x="970" y="40" width="90" height="70" as="geometry"/>
                </mxCell>
                <!-- Audit record -->
                <mxCell id="audit-write" value="Lifecycle audit entry&#xa;action: &quot;delete&quot;&#xa;triggerSource: cron_cleanup_404" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
                    <mxGeometry x="440" y="670" width="280" height="60" as="geometry"/>
                </mxCell>
                <!-- Browser note -->
                <mxCell id="browser-note" value="Browser-local artifacts&#xa;(drafts, consent, tour state)&#xa;are NOT cleared server-side." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;" vertex="1" parent="1">
                    <mxGeometry x="820" y="670" width="240" height="60" as="geometry"/>
