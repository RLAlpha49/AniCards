                <mxCell id="fetch-cards" value="GET /api/get-cards&#xa;?userId=..." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lane-lookup" vertex="1">
                    <mxGeometry x="590" y="40" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="init-server" value="initializeFromServerData()&#xa;normalize, seed missing cards,&#xa;capture baselines" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lane-lookup" vertex="1">
                    <mxGeometry x="840" y="40" width="220" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="lane-new" value="New User Setup (useNewUserSetup)" style="swimlane;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" parent="1" vertex="1">
