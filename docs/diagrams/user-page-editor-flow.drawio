                <mxCell id="draft-notice" value="Show draft notice:&#xa;Restore / Discard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="lane-draft" vertex="1">
