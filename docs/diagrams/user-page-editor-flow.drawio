    <diagram id="editor-autosave" name="Autosave and Conflict Resolution">
        <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1050" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <!-- Title -->
                <mxCell id="title" value="User Page Editor: Autosave and Conflict Resolution" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=18;fontStyle=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="500" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="note" value="Debounced autosave path, local draft backup, and server conflict recovery." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="620" y="20" width="440" height="40" as="geometry"/>
                </mxCell>
                <!-- User action -->
                <mxCell id="start" value="User edits card settings&#xa;(color, variant, flags, order)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="410" y="80" width="320" height="60" as="geometry"/>
                </mxCell>
                <!-- Store update -->
                <mxCell id="store-update" value="Editor store marks isDirty=true" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="450" y="170" width="240" height="50" as="geometry"/>
                </mxCell>
                <!-- Two parallel paths -->
                <mxCell id="lane-autosave" value="Autosave Path (useCardAutoSave)" style="swimlane;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="260" width="530" height="260" as="geometry"/>
                </mxCell>
                <mxCell id="debounce" value="Schedule save&#xa;autoSaveDueAt = now + 1500ms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="lane-autosave" vertex="1">
                    <mxGeometry x="30" y="50" width="230" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="build-patch" value="buildLocalEditsPatch()&#xa;diff from baselines" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="lane-autosave" vertex="1">
                    <mxGeometry x="300" y="50" width="200" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="post-save" value="POST /api/store-cards&#xa;cards + globalSettings diff&#xa;+ ifMatchUpdatedAt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="lane-autosave" vertex="1">
                    <mxGeometry x="30" y="130" width="240" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="d-save-result" value="Result?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="lane-autosave" vertex="1">
                    <mxGeometry x="320" y="130" width="120" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="lane-draft" value="Local Draft Backup (useUserPageDraftBackup)" style="swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="610" y="260" width="460" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="draft-debounce" value="Debounce 750ms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lane-draft" vertex="1">
                    <mxGeometry x="30" y="50" width="160" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="draft-write" value="writeUserPageDraft(userId, patch)&#xa;to localStorage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lane-draft" vertex="1">
                    <mxGeometry x="220" y="50" width="220" height="50" as="geometry"/>
                </mxCell>
                <!-- Save outcomes -->
