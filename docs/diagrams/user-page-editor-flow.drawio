                <mxCell id="d-draft" value="Draft exists &amp;amp;&#xa;editor is clean?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="lane-draft" vertex="1">
