                    <mxGeometry x="30" y="40" width="220" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="validate-input" value="Validate identifier&#xa;userId: numeric&#xa;username: isValidUsername()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="lane-route" vertex="1">
