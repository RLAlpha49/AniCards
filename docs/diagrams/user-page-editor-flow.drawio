                <mxCell id="fetch-user" value="GET /api/get-user&#xa;?view=bootstrap&#xa;loads USER_BOOTSTRAP_DATA_PARTS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="lane-lookup" vertex="1">
                    <mxGeometry x="30" y="40" width="260" height="60" as="geometry"/>
