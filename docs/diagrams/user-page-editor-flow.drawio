                <mxCell id="lane-draft" value="Draft Recovery (after bootstrap completes)" style="swimlane;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="650" width="1080" height="140" as="geometry"/>
