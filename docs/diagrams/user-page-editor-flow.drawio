                <mxCell id="read-draft" value="readUserPageDraft(userId)&#xa;from localStorage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="lane-draft" vertex="1">
                    <mxGeometry x="30" y="50" width="220" height="50" as="geometry"/>
