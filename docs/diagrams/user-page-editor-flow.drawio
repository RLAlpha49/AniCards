    <diagram id="editor-bootstrap" name="Editor Bootstrap Flow">
        <mxGraphModel dx="870" dy="535" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1200" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="User Page Editor: Bootstrap Flow" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=18;fontStyle=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="400" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="note" value="First-time and returning user bootstrap, including AniList identity resolution, server persistence, and editor hydration." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="540" y="20" width="520" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="start" value="User navigates to&#xa;/user/[username] or /user?userId=..." style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="410" y="80" width="320" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="lane-route" value="Route Resolution" style="swimlane;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" parent="1" vertex="1">
