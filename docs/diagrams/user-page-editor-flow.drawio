                    <mxGeometry x="610" y="900" width="320" height="50" as="geometry"/>
                </mxCell>
                <!-- Edges -->
                <mxCell id="e-start-store" style="edgeStyle=orthogonalEdgeStyle;html=1;" parent="1" source="start" target="store-update" edge="1">
