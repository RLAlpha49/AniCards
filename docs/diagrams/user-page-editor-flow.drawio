                <mxCell id="hydrate-new" value="initializeFromServerData()&#xa;with starter snapshot" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="lane-new" vertex="1">
                    <mxGeometry x="870" y="50" width="190" height="60" as="geometry"/>
