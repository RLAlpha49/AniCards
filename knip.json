{
  "$schema": "./node_modules/knip/schema.json",
  "entry": [
    "app/**/*.{ts,tsx,mjs}",
    "tests/**/*.{ts,tsx,mjs}",
    "*.ts",
    "*.mjs"
  ],
  "project": [
    "app/**/*.{ts,tsx,mjs}",
    "components/**/*.{ts,tsx,mjs}",
    "hooks/**/*.{ts,tsx,mjs}",
    "lib/**/*.{ts,tsx,mjs}",
    "tests/**/*.{ts,tsx,mjs}",
    "*.ts",
    "*.mjs"
  ],
  "ignoreIssues": {
    "lib/svg-templates/**": ["exports"]
  },
  "tags": ["-@internal"],
  "ignoreDependencies": ["postcss-load-config"],
  "ignoreBinaries": ["AGPL", "LGPL", "NGPL"],
  "exclude": ["devDependencies"],
  "ignoreExportsUsedInFile": true
}
