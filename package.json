{
  "name": "anilist-stat-cards",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "typecheck": "tsc --noEmit",
    "format:write": "prettier --write . && eslint . --fix",
    "update": "bunx npm-check-updates -u --target minor",
    "check:licenses": "bunx license-checker-rseidelsohn --production --summary --failOn \"GPL;AGPL;LGPL;NGPL\"",
    "test:unit": "bun test",
    "test:unit:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=.artifacts/coverage",
    "test": "bun run test:unit && bun run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:deployed-smoke": "playwright test tests/e2e/smoke/unmocked-app-shell.spec.ts --grep \"serves the home app shell|serves robots.txt\"",
    "check:unused": "bunx knip",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,mts}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.23",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dompurify": "3.3.3",
    "driver.js": "^1.4.0",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.1.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.43",
    "lru-cache": "^11.2.7",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "simple-icons": "^16.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/eslint-plugin-next": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bun": "^1.3.11",
    "@types/dompurify": "^3.2.0",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.1.0",
    "eslint-config-next": "16.2.1",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "knip": "^6.0.6",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  },
  "overrides": {
    "flatted": "3.4.2",
    "minimatch": ">=3.1.6",
    "picomatch": ">=4.0.4",
    "smol-toml": ">=1.6.1",
    "yaml": ">=2.8.3"
  }
}
