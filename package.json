{
  "name": "anilist-stat-cards",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "x-anicards-override-review": {
    "entries": {
      "@emnapi/runtime": "Temporary semver-compatible dedupe override to collapse wasm-runtime consumers onto 1.9.0 while sharp-related and resolver transitive ranges catch up.",
      "flatted": "Keeps flat-cache on a patched transitive release while upstream ranges still allow older versions.",
      "minimatch": "Applies a minimum safe floor for legacy transitive consumers that still request older vulnerable 3.x releases.",
      "picomatch": "Applies a minimum safe floor for tooling transitive consumers while upstream ranges still allow older 4.x releases.",
      "smol-toml": "Keeps Knip's TOML parser dependency on a patched minimum release.",
      "yaml": "Applies a minimum safe floor for CLI and tooling consumers such as Knip and lint-staged."
    }
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "typecheck": "tsc --noEmit",
    "format:write": "prettier --write . && eslint . --fix",
    "update": "bun run update:apply",
    "update:check": "npm-check-updates --target minor",
    "update:check:json": "npm-check-updates --target minor --jsonUpgraded",
    "update:apply": "npm-check-updates -u --target minor",
    "check:licenses": "node ./scripts/check-licenses.mjs",
    "generate:sbom": "node -e \"require('node:fs').mkdirSync('.artifacts/sbom', { recursive: true });\" && cdxgen -t js --no-install-deps --required-only --spec-version 1.6 --output .artifacts/sbom/anicards.cdx.json .",
    "test:unit": "bun test",
    "test:unit:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=.artifacts/coverage",
    "test": "bun run test:unit && bun run test:e2e",
    "test:e2e": "bun ./scripts/run-playwright.ts test-e2e",
    "test:e2e:local-prod": "bun ./scripts/run-playwright.ts local-prod",
    "test:e2e:deployed-smoke": "bun ./scripts/run-playwright.ts deployed-smoke",
    "check:unused": "bunx knip",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,mts}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@napi-rs/canvas": "^0.1.97",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.23",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dompurify": "3.4.0",
    "driver.js": "^1.4.0",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.3.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.45",
    "lru-cache": "^11.3.5",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.5",
    "simple-icons": "^16.16.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/env": "16.2.3",
    "@next/eslint-plugin-next": "16.2.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.12",
    "@types/dompurify": "^3.2.0",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@cyclonedx/cdxgen": "^12.1.5",
    "eslint": "^10.2.0",
    "eslint-config-next": "16.2.3",
    "eslint-plugin-better-tailwindcss": "^4.4.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "knip": "^6.4.1",
    "license-checker-rseidelsohn": "^4.4.2",
    "lint-staged": "^16.4.0",
    "npm-check-updates": "^21.0.0",
    "postcss": "^8.5.9",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  },
  "overrides": {
    "@emnapi/runtime": "1.9.0",
    "flatted": "3.4.2",
    "minimatch": ">=3.1.6",
    "picomatch": ">=4.0.4",
    "smol-toml": ">=1.6.1",
    "yaml": ">=2.8.3"
  }
}
