# AniCards example env file. Copy to `.env.local` for local dev, or update with production values when deploying.

# AniList GraphQL token (server):
ANILIST_TOKEN=

# Upstash Redis connection (server):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Analytics & Site configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# Card SVG CORS origin (restrict in production)
NEXT_PUBLIC_CARD_SVG_ALLOWED_ORIGIN=

# Cron secret used to authenticate background cron endpoints (required outside local dev)
CRON_SECRET=changeme

# Set to 1 only for local development if you intentionally want unsecured cron access.
ALLOW_UNSECURED_CRON_IN_DEV=

# Set to 1 to force AniList upstream callers into degraded mode when the upstream is unhealthy.
ANILIST_UPSTREAM_DEGRADED_MODE=

# Vercel (set in production hosting) - don't use in local .env; the value gets set by the platform
VERCEL=

# Use `VERCEL=1` in production if needed; keep empty in local dev
